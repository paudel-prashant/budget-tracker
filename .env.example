# Finance Tracker - Environment Variables
# Copy to .env for local development: cp .env.example .env

# =============================================================================
# DATABASE (required)
# =============================================================================

# Pooled connection used by the app at runtime (Prisma Client).
# Local PostgreSQL example:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finance_tracker?schema=public"

# Direct (non-pooled) connection for Prisma migrations.
# Required when DATABASE_URL uses a connection pooler (e.g. Vercel Postgres).
# For local Postgres without pooling, set the same value as DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/finance_tracker?schema=public"

# =============================================================================
# VERCEL POSTGRES (production - set in Vercel dashboard)
# =============================================================================
# When you link Vercel Postgres storage, these variables are created automatically:
#
#   POSTGRES_URL              - pooled connection
#   POSTGRES_PRISMA_URL       - Prisma-optimized pooled URL (recommended)
#   POSTGRES_URL_NON_POOLING  - direct connection for migrations
#
# Map them in Vercel > Project > Settings > Environment Variables:
#
#   DATABASE_URL  = POSTGRES_PRISMA_URL
#   DIRECT_URL    = POSTGRES_URL_NON_POOLING
#
# Apply to Production, Preview, and Development environments as needed.

# =============================================================================
# OPTIONAL
# =============================================================================
# NODE_ENV=development
